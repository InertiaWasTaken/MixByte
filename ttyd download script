wget https://github.com/tsl0922/ttyd/releases/latest/download/ttyd.aarch64
chmod +x ttyd.aarch64
sudo mv ttyd.aarch64 /usr/local/bin/ttyd
ttyd --version
sudo nano /etc/systemd/system/mixbyte-terminal.service

"
[Unit]
